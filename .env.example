VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_ADMIN_PASSWORD=hear-direct-admin
# Optioneel: service role voor server-webhooks (aanbevolen)
SUPABASE_SERVICE_ROLE_KEY=
# Geheim voor POST /api/webhooks/leads (Bearer of X-Webhook-Secret header)
LEAD_WEBHOOK_SECRET=
# Optioneel: basis-URL voor testlinks in webhook-response
APP_URL=https://jouw-domein.nl
# api-postcode.nl token (server-side proxy, niet in de browser)
POSTCODE_API_KEY=
ANTHROPIC_API_KEY=
# Postmark (e-mail via info@hoorweer.nl)
POSTMARK_SERVER_TOKEN=
